# Preferred: point this at a separate local Florence-2 grounding service.
FLORENCE2_TASK=<CAPTION_TO_PHRASE_GROUNDING>
FLORENCE2_LOCAL_ENDPOINT=
FLORENCE2_LOCAL_TIMEOUT_SECONDS=10

# Optional in-process fallback when no local service endpoint is configured.
FLORENCE2_MODEL_ID=microsoft/Florence-2-base-ft
FLORENCE2_DEVICE=cuda:1
MM_EVENT_USE_VLM_PERCEPTION=false
MM_EVENT_PERCEPTION_BACKEND=openai_compatible
MM_EVENT_PERCEPTION_MODEL_NAME=qwen3.5-plus
