MM_EVENT_TYPE_MODE=closed_set
MM_EVENT_DEBUG=false
MM_AGENT_LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=30

TAVILY_API_KEY=
MM_EVENT_TAVILY_ENDPOINT=https://api.tavily.com/search
MM_EVENT_SEARCH_TIMEOUT_SECONDS=8
MM_EVENT_SEARCH_MAX_RESULTS=5
MM_EVENT_SEARCH_TOP_K=3
MM_EVENT_SEARCH_MIN_RELEVANCE=0.18

FLORENCE2_MODEL_ID=microsoft/Florence-2-base-ft
FLORENCE2_TASK=<OPEN_VOCABULARY_DETECTION>
FLORENCE2_DEVICE=

FLORENCE2_LOCAL_ENDPOINT=
FLORENCE2_LOCAL_TIMEOUT_SECONDS=10

# Keep the current demo in-memory corpus enabled by default.
MM_EVENT_RAG_USE_PERSISTENT_INDEX=false
MM_EVENT_RAG_USE_DEMO_CORPUS=true
MM_EVENT_RAG_INDEX_ROOT=data/rag/indexes
MM_EVENT_RAG_QWEN_MODEL_PATH=
MM_EVENT_RAG_QWEN_DEVICE=cuda:0
MM_EVENT_RAG_QWEN_DTYPE=bfloat16
MM_EVENT_RAG_QWEN_ATTN_IMPL=sdpa
# Deprecated compatibility knobs for the old sentence-transformers path.
MM_EVENT_RAG_TEXT_ENCODER_MODEL=sentence-transformers/all-MiniLM-L6-v2
MM_EVENT_RAG_TEXT_ENCODER_MODEL_PATH=
MM_EVENT_RAG_QWEN_EMBEDDING_MODEL_PATH=
MM_EVENT_RAG_QWEN_EMBEDDING_DEVICE=cuda:0
MM_EVENT_RAG_QWEN_EMBEDDING_DTYPE=bfloat16
MM_EVENT_RAG_QWEN_EMBEDDING_ATTN_IMPL=sdpa
MM_EVENT_RAG_QWEN_TEXT_INSTRUCTION=Retrieve text relevant to the user's query.
MM_EVENT_RAG_QWEN_IMAGE_INSTRUCTION=Retrieve images relevant to the user's query.
MM_EVENT_RAG_QWEN_EMBEDDING_OUT_DIM=0
MM_EVENT_RAG_QWEN_EMBEDDING_NORMALIZE=true
MM_EVENT_RAG_IMAGE_ENCODER_MODEL_PATH=
MM_EVENT_RAG_IMAGE_ENCODER_DEVICE=
MM_EVENT_RAG_ACE_TEXT_INDEX_DIR=
MM_EVENT_RAG_MAVEN_TEXT_INDEX_DIR=
MM_EVENT_RAG_SWIG_TEXT_INDEX_DIR=
MM_EVENT_RAG_SWIG_IMAGE_INDEX_DIR=
MM_EVENT_RAG_BRIDGE_INDEX_DIR=
MM_EVENT_RAG_DEFAULT_TOP_K=3
MM_EVENT_RAG_TEXT_TOP_K=3
MM_EVENT_RAG_IMAGE_TOP_K=3
MM_EVENT_RAG_BRIDGE_TOP_K=3
MM_EVENT_RAG_ENABLE_IMAGE_QUERY=true
